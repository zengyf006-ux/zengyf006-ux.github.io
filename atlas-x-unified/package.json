{
  "name": "@atlas-x/unified",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "generate:contracts": "openapi-typescript openapi/atlas-x.openapi.yaml -o src/generated/contracts.ts",
    "check:generated": "node scripts/check-generated.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run check:generated && npm run typecheck && npm test && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "decimal.js": "10.6.0"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "vitest": "3.2.7",
    "yaml": "2.9.0"
  }
}
